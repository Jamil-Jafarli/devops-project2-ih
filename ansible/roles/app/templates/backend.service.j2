[Unit]
Description=Burger Builder Backend (Spring Boot)
After=network.target

[Service]
Type=simple
User={{ app_user }}
WorkingDirectory={{ app_dir }}/backend
EnvironmentFile={{ app_dir }}/backend/environment.env
ExecStart=/usr/bin/mvn spring-boot:run
Restart=on-failure
RestartSec=15
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
